---
layout: layouts/base.njk
title: Home
---

<section class="hero">

<h1>{{ site.title }}</h1>

<p>{{ site.description }}</p>

</section>

<section class="feed">

{% for post in collections.all | reverse %}

<article class="post-preview">

<h2>
<a href="{{ post.url }}">
{{ post.data.title }}
</a>
</h2>

<p>{{ post.data.description }}</p>

</article>

{% endfor %}

</section>